# Copy to .env and fill in. python-decouple reads this.
SECRET_KEY=change-me
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1,api.domain.com

# sqlite (dev) or mysql (production)
DB_ENGINE=sqlite
# DB_NAME=carshop
# DB_USER=carshop
# DB_PASSWORD=secret
# DB_HOST=localhost
# DB_PORT=3306

SITE_BASE_URL=http://localhost:3000
API_BASE_URL=http://localhost:8000
REVALIDATE_SECRET=dev-revalidate-secret
CLOUDFLARE_ZONE_ID=
CLOUDFLARE_API_TOKEN=
